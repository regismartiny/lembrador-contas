<%- include ('../partials/header.ejs') %>

    <body>
        <%- template.navbar %>
            <div class="container">
                <div class="starter-template">
                    <h1 class="title-1">
                        <%= title %>
                    </h1>
                    <br>
                    <form id="form" action="/tables/<% if (locals.table) {%>update<% }else{ %>add<% } %>" method="post" class="justify-content-center">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <% if (locals.table) {%>
                            <input type="hidden" name="id" value="<%= table._id %>">
                            <% } %>
                                <div class="form-group">
                                    <label for="company">Nome</label>
                                    <input type="text" class="form-control" id="name" name="name" placeholder="Nome" aria-describedby="basic-addon1" required <% if (locals.table)
                                        { %>value="<%= table.name %>"<% } %>>
                                </div>
                                <% if (locals.table) {%>
                                    <div class="form-group">
                                        <label for="status">Situação</label>
                                        <select name='status' class="form-control" id="status">
                                            <% var keys = Object.keys(statusEnum); keys.forEach(function(vst){ %>
                                                <option <% if (vst == table.status) {%>selected="selected"<% } %> value="<%= vst %>"><%= statusEnum[vst] %></option>
                                            <%})%>
                                        </select>
                                    </div>
                                <% } %>
                                <br>
                                <div class="table-responsive">
                                    <table id="table" class="table table-edit">
                                        <colgroup>
                                            <col class="col-period">
                                            <col class="col-value">
                                            <col class="col-actions">
                                        </colgroup>
                                        <thead>
                                            <tr>
                                                <th>Período</th>
                                                <th>Valor</th>
                                                <th></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                        </tbody>
                                    </table>
                                </div>
                                <div class="period-fill-section">
                                    <p class="period-fill-label">Preencher período</p>
                                    <div class="period-fill-row">
                                        <div class="form-group mb-0 flex-fill">
                                            <label for="fill-start">De</label>
                                            <input type="month" class="form-control form-control-sm" id="fill-start">
                                        </div>
                                        <div class="form-group mb-0 flex-fill">
                                            <label for="fill-end">Até</label>
                                            <input type="month" class="form-control form-control-sm" id="fill-end">
                                        </div>
                                    </div>
                                    <div class="period-fill-row mt-2">
                                        <div class="form-group mb-0 flex-fill">
                                            <label for="fill-value">Valor</label>
                                            <input type="text" class="form-control form-control-sm money" id="fill-value" placeholder="0,00">
                                        </div>
                                        <div class="form-group mb-0 period-fill-btn-wrap">
                                            <label>&nbsp;</label>
                                            <button type="button" class="btn btn-secondary btn-sm btn-block" onclick="fillPeriod()">Preencher</button>
                                        </div>
                                    </div>
                                </div>
                                <div class="mt-1">
                                    <a href="javascript:addRow()">+ Adicionar linha</a>
                                </div>
                                <br>
                                <br>
                                <div class="form-group-btn">
                                    <input type="submit" class="btn btn-primary center-block" value="Salvar" />
                                    <a href="/tables/list" class="btn btn-secondary center-block">Cancelar</a>
                                </div>
                    </form>
                </div>
            </div>
            <%- template.scripts %>
                <script>
                    var rowCount = 0;

                    <% if (locals.table) { %>
                        var dataJSON = '<%- JSON.stringify(table.data) %>';
                        var data = JSON.parse(dataJSON);

                        for (line of data) {
                            createRow(line.period, line.value);
                        }
                    <% } else { %>
                        createRow({ month: 1, year: new Date().getFullYear() }, 0);
                    <% } %>

                    function createRow(period, value) {
                        period = period.year + '-' + n(period.month);
                        addRow(period, value);
                    }

                    function n(n) {
                        return n > 9 ? "" + n : "0" + n;
                    }

                    function addRow(periodValue, valueValue) {
                        var table = $('#table tr:last').after('<tr id="row-' + rowCount + '">' + genPeriodCol(periodValue) + genValueCol(valueValue) + genRemoveAction() + '</tr>');
                        rowCount++;
                    }

                    function removeRow(rowNumber) {
                        $('#row-' + rowNumber).remove();
                        rowCount--;
                    }

                    function genPeriodCol(value) {
                        var parts = (value || '').split('-');
                        var year = parts[0] || new Date().getFullYear();
                        var month = parts[1] ? parseInt(parts[1].replace('0','')) : 1;
                        return '<td><div class="period-compact"><input type="hidden" name="period" value="' + year + '-' + n(month) + '" id="hperiod-' + rowCount + '"><select class="form-control form-control-sm period-month">' +
                            ['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'].map(function(m, i) {
                                return '<option value="' + (i+1) + '"' + ((month===i+1)?' selected':'') + '>' + m + '</option>';
                            }).join('') + '</select><input type="number" class="form-control form-control-sm period-year" value="' + year + '"></div></td>';
                    }

                    function genValueCol(value) {
                        return '<td><input type="text" class="form-control form-control-sm money" placeholder="0,00" id="value-' + rowCount + '" name="value" required/></td>'
                    }

                    function genRemoveAction() {
                        return '<td><a href="javascript:removeRow(' + rowCount + ')"><span class="material-symbols-outlined">delete</span></a></td>';
                    }

                    $( document ).ready(function() {
                        if (data) {
                            var i=0
                            for (line of data) {
                                $(`#value-${i}`).val(line.value)
                                i++
                            }
                        }

                        $('#table').on('change', '.period-month, .period-year', function() {
                            var $row = $(this).closest('tr');
                            var month = $row.find('.period-month').val();
                            var year = $row.find('.period-year').val();
                            if (month && year) {
                                $row.find('[name="period"]').val(year + '-' + n(parseInt(month)));
                            }
                        });
                    });

                    function fillPeriod() {
                        var start = document.getElementById('fill-start').value;
                        var end = document.getElementById('fill-end').value;
                        var value = document.getElementById('fill-value').value;

                        if (!start || !end) {
                            alert('Informe o período inicial e final.');
                            return;
                        }

                        var startDate = new Date(start + '-02');
                        var endDate = new Date(end + '-02');

                        if (startDate > endDate) {
                            alert('O período inicial deve ser anterior ao final.');
                            return;
                        }

                        var current = new Date(startDate);
                        var addedIds = [];
                        while (current <= endDate) {
                            var y = current.getFullYear();
                            var m = n(current.getMonth() + 1);
                            addedIds.push(rowCount);
                            addRow(y + '-' + m, null);
                            current.setMonth(current.getMonth() + 1);
                        }

                        if (value) {
                            addedIds.forEach(function(id) {
                                $('#value-' + id).val(value);
                            });
                        }
                    }

                    $('#form').submit(function() {
                        //actions before submitting form
                        return true;
                    });
                </script>
                <style>
                    /* ---- edit table columns ---- */
                    .table-edit { table-layout: fixed; width: 100%; }
                    .col-period  { width: 180px; }
                    .col-value   { width: 90px; }
                    .col-actions { width: 44px; }
                    .table-edit td { vertical-align: middle; overflow: hidden; }
                    .table-edit input, .table-edit select { min-width: 0; width: 100%; }
                    .period-compact { display: flex; gap: 2px; align-items: center; }
                    .period-compact select, .period-year { font-size: 1rem !important; }
                    .period-compact select { width: auto; flex-shrink: 0; }
                    .period-year { width: 56px; text-align: center; padding-left: 2px; padding-right: 2px; }

                    @media (max-width: 600px) {
                        .col-period  { width: 140px; }
                        .col-value   { width: auto; }
                        .period-compact select { font-size: 1rem !important; padding: 2px 1px; min-width: 56px; }
                        .period-year { width: 48px; font-size: 1rem !important; }
                    }

                    /* ---- fill period panel ---- */
                    .period-fill-section {
                        margin: 0.75rem 0;
                        padding: 0.75rem 1rem;
                        border: 1px solid var(--border);
                        border-radius: 0.375rem;
                        background: var(--bg-elevated);
                    }
                    .period-fill-label {
                        font-size: 0.78rem;
                        text-transform: uppercase;
                        letter-spacing: 0.05em;
                        color: var(--text-secondary);
                        margin-bottom: 0.5rem;
                    }
                    .period-fill-row {
                        display: flex;
                        gap: 0.5rem;
                        align-items: flex-end;
                    }
                    .period-fill-row .flex-fill { min-width: 0; flex: 1 1 0; }
                    .period-fill-row .flex-fill .form-control { width: 100%; min-width: 0; }
                    .period-fill-btn-wrap { flex-shrink: 0; }
                    .period-fill-btn-wrap button { white-space: nowrap; }
                </style>
    </body>

    </html>