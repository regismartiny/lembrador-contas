<%- include ('../partials/header.ejs') %>

<style>
  body {
    padding-top: 0 !important;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #1a2a4a 0%, #0d1b35 100%);
  }

  html.light-theme body {
    background: linear-gradient(135deg, #e8f0fe 0%, #c5d8ff 100%);
  }

  .login-wrapper {
    width: 100%;
    max-width: 380px;
    padding: 1rem;
    animation: fadeUp 0.35s ease both;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .login-card {
    background-color: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 16px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.35);
    padding: 2.5rem 2rem;
  }

  html.light-theme .login-card {
    box-shadow: 0 8px 32px rgba(0,0,0,0.12);
  }

  .login-logo {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 2rem;
  }

  .login-logo-icon {
    width: 64px;
    height: 64px;
    border-radius: 16px;
    background: linear-gradient(135deg, #3a7bd5 0%, #1a4fa0 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    box-shadow: 0 4px 16px rgba(58,123,213,0.4);
  }

  .login-logo-icon i {
    font-size: 2rem;
    color: #fff;
  }

  .login-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
    text-align: center;
  }

  .login-subtitle {
    font-size: 0.8rem;
    color: var(--text-secondary);
    margin-top: 0.25rem;
    text-align: center;
  }

  .login-card .form-label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-secondary);
    margin-bottom: 0.4rem;
  }

  .password-wrapper {
    position: relative;
  }

  .password-wrapper .form-control {
    padding-right: 2.75rem;
    border-radius: 8px;
    font-size: 1rem;
  }

  .password-toggle {
    position: absolute;
    right: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    padding: 0;
    color: var(--text-secondary);
    cursor: pointer;
    line-height: 1;
  }

  .password-toggle:hover { color: var(--text-primary); }

  .btn-login {
    width: 100%;
    padding: 0.65rem;
    font-size: 1rem;
    font-weight: 600;
    border-radius: 8px;
    background: linear-gradient(135deg, #3a7bd5 0%, #1a4fa0 100%);
    border: none;
    color: #fff;
    margin-top: 1.5rem;
    transition: opacity 0.2s, transform 0.1s;
  }

  .btn-login:hover  { opacity: 0.9; color: #fff; }
  .btn-login:active { transform: scale(0.98); }

  .alert-danger {
    border-radius: 8px;
    font-size: 0.9rem;
    margin-bottom: 1.25rem;
  }
</style>

<body>
  <div class="login-wrapper">
    <div class="login-card">

      <div class="login-logo">
        <div class="login-logo-icon">
          <i class="material-icons">receipt_long</i>
        </div>
        <p class="login-title">Lembrador de Contas</p>
        <p class="login-subtitle">Digite seu e-mail e senha para continuar</p>
      </div>

      <% if (error) { %>
        <div class="alert alert-danger py-2">
          <i class="material-icons align-middle" style="font-size:1rem;margin-right:4px;">error_outline</i>
          <%= error %>
        </div>
      <% } %>

      <form action="/login" method="post">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="form-group">
          <label class="form-label" for="email">E-mail</label>
          <input type="email" class="form-control" id="email" name="email"
            placeholder="seu@email.com" autofocus required style="border-radius:8px;font-size:1rem;">
        </div>

        <div class="form-group mb-0">
          <label class="form-label" for="password">Senha</label>
          <div class="password-wrapper">
            <input type="password" class="form-control" id="password" name="password"
              placeholder="Digite a senha" required>
            <button type="button" class="password-toggle" onclick="togglePassword()" tabindex="-1"
              aria-label="Mostrar/ocultar senha">
              <i class="material-icons" id="toggleIcon" style="font-size:1.25rem;">visibility</i>
            </button>
          </div>
        </div>

        <button type="submit" class="btn btn-login">Entrar</button>
      </form>

    </div>
  </div>

  <script>
    document.querySelector('form').addEventListener('keydown', function (e) {
      if (e.key === 'Enter') { e.preventDefault(); this.submit(); }
    });

    function togglePassword() {
      var input = document.getElementById('password');
      var icon  = document.getElementById('toggleIcon');
      if (input.type === 'password') {
        input.type = 'text';
        icon.textContent = 'visibility_off';
      } else {
        input.type = 'password';
        icon.textContent = 'visibility';
      }
    }
  </script>
</body>
</html>
