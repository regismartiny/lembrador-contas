<%- include ('../partials/header.ejs') %>

<style>
  body {
    padding-top: 0 !important;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-page);
    position: relative;
    overflow: hidden;
  }

  body::before {
    content: '';
    position: fixed;
    top: -40%;
    left: -20%;
    width: 80%;
    height: 80%;
    background: radial-gradient(ellipse, rgba(108, 140, 255, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  body::after {
    content: '';
    position: fixed;
    bottom: -30%;
    right: -20%;
    width: 70%;
    height: 70%;
    background: radial-gradient(ellipse, rgba(108, 140, 255, 0.05) 0%, transparent 70%);
    pointer-events: none;
  }

  html.light-theme body::before {
    background: radial-gradient(ellipse, rgba(74, 108, 247, 0.06) 0%, transparent 70%);
  }

  html.light-theme body::after {
    background: radial-gradient(ellipse, rgba(74, 108, 247, 0.04) 0%, transparent 70%);
  }

  .login-wrapper {
    width: 100%;
    max-width: 400px;
    padding: 1rem;
    animation: fadeUp 0.4s cubic-bezier(0.4, 0, 0.2, 1) both;
    position: relative;
    z-index: 1;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .login-card {
    background-color: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 20px;
    box-shadow: var(--shadow-lg);
    padding: 2.5rem 2rem;
  }

  .login-logo {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 2rem;
  }

  .login-logo-icon {
    width: 56px;
    height: 56px;
    border-radius: 16px;
    background: linear-gradient(135deg, var(--accent) 0%, #4a5fd4 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    box-shadow: 0 4px 20px rgba(108, 140, 255, 0.25);
  }

  .login-logo-icon i {
    font-size: 1.75rem;
    color: #fff;
  }

  .login-title {
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
    text-align: center;
    letter-spacing: -0.02em;
  }

  .login-subtitle {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-top: 0.35rem;
    text-align: center;
  }

  .login-card .form-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-secondary);
    margin-bottom: 0.4rem;
  }

  .password-wrapper {
    position: relative;
  }

  .password-wrapper .form-control {
    padding-right: 2.75rem;
    font-size: 1rem;
  }

  .password-toggle {
    position: absolute;
    right: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    padding: 0;
    color: var(--text-secondary);
    cursor: pointer;
    line-height: 1;
    transition: color var(--transition);
  }

  .password-toggle:hover { color: var(--text-primary); }

  .btn-login {
    width: 100%;
    padding: 0.7rem;
    font-size: 0.95rem;
    font-weight: 600;
    font-family: var(--font);
    border-radius: var(--radius-sm);
    background: linear-gradient(135deg, var(--accent) 0%, #4a5fd4 100%);
    border: none;
    color: #fff;
    margin-top: 1.5rem;
    transition: all 0.2s ease;
  }

  .btn-login:hover  { opacity: 0.9; color: #fff; transform: translateY(-1px); box-shadow: 0 4px 16px rgba(108, 140, 255, 0.3); }
  .btn-login:active { transform: translateY(0); }

  .alert-danger {
    border-radius: var(--radius);
    font-size: 0.875rem;
    margin-bottom: 1.25rem;
    border: 1px solid rgba(242, 92, 92, 0.2);
    background: rgba(242, 92, 92, 0.08);
  }
</style>

<body>
  <div class="login-wrapper">
    <div class="login-card">

      <div class="login-logo">
        <div class="login-logo-icon">
          <i class="material-icons">receipt_long</i>
        </div>
        <p class="login-title">Lembrador de Contas</p>
        <p class="login-subtitle">Digite seu e-mail e senha para continuar</p>
      </div>

      <% if (error) { %>
        <div class="alert alert-danger py-2">
          <i class="material-icons align-middle" style="font-size:1rem;margin-right:4px;">error_outline</i>
          <%= error %>
        </div>
      <% } %>

      <form action="/login" method="post">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="form-group">
          <label class="form-label" for="email">E-mail</label>
          <input type="email" class="form-control" id="email" name="email"
            placeholder="seu@email.com" autofocus required>
        </div>

        <div class="form-group mb-0">
          <label class="form-label" for="password">Senha</label>
          <div class="password-wrapper">
            <input type="password" class="form-control" id="password" name="password"
              placeholder="Digite a senha" required>
            <button type="button" class="password-toggle" onclick="togglePassword()" tabindex="-1"
              aria-label="Mostrar/ocultar senha">
              <i class="material-icons" id="toggleIcon" style="font-size:1.25rem;">visibility</i>
            </button>
          </div>
        </div>

        <button type="submit" class="btn btn-login">Entrar</button>
      </form>

    </div>
  </div>

  <script>
    document.querySelector('form').addEventListener('keydown', function (e) {
      if (e.key === 'Enter') { e.preventDefault(); this.submit(); }
    });

    function togglePassword() {
      var input = document.getElementById('password');
      var icon  = document.getElementById('toggleIcon');
      if (input.type === 'password') {
        input.type = 'text';
        icon.textContent = 'visibility_off';
      } else {
        input.type = 'password';
        icon.textContent = 'visibility';
      }
    }
  </script>
</body>
</html>
