
 <% if (!userBillsData?.billListPerMonth?.length) { %>
     <p class="text-muted text-center py-4">Nenhuma conta encontrada para o período selecionado.</p>
 <% } %>
 <%
var monthNames = ['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'];
function formatMonth(m) {
    var parts = m.split('/');
    return monthNames[parseInt(parts[0], 10) - 1] + '/' + parts[1];
}
var currentM = currentMonth || (new Date().getMonth() + 1);
var currentY = currentYear || new Date().getFullYear();
 %>
 <% userBillsData?.billListPerMonth?.forEach(function(data){ %>
     <% var mParts = data.month.split('/'); %>
     <% var billM = parseInt(mParts[0], 10); %>
     <% var billY = parseInt(mParts[1], 10); %>
     <% var isCurrent = (billM === currentM && billY === currentY); %>
     <% var isPast = ((billY < currentY) || (billY === currentY && billM < currentM)); %>
     <% var monthClass = isPast ? 'month-block month-closed' : (isCurrent ? 'month-block month-current' : 'month-block month-future'); %>
     <div class="<%= monthClass %>">
        <div class="month-header-row">
            <h2 class="month-title"><%= formatMonth(data.month) %></h2>
            <span class="month-total">Total: <strong class="money"><%= Number(data.totalValue).toFixed(2) %></strong></span>
        </div>
        <div class="payment-badges">
            <% data.paymentTypeSummaries?.forEach(function(summary){ %>
                <span class="badge badge-secondary">
                    <%= summary.type %>: <span class="money"><%= Number(summary.total).toFixed(2) %></span>
                </span>
            <% }) %>
        </div>
        <div class="table-responsive">
            <table class="table bill-table">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th class="d-none d-sm-table-cell">Venc.</th>
                        <th>Valor</th>
                    </tr>
                </thead>
                <tbody>
                    <% data.billList?.forEach(function(bill){ %>
                        <tr>
                            <td><%= bill.name %></td>
                            <td class="d-none d-sm-table-cell"><span class="date"><%= bill?.dueDate?.toLocaleDateString('pt-br') %></span></td>
                            <td><span class="money"><%= bill.value ? Number(bill.value).toFixed(2) : '' %></span></td>
                        </tr>
                    <%})%>
                </tbody>
            </table>
        </div>
    </div>
<%})%>
