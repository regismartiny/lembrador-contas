<%- include ('../partials/header.ejs') %>

    <body>
        <%- template.navbar %>
            <div class="container">
                <div class="starter-template">
                    <div class="d-flex justify-content-between align-items-start flex-wrap mb-2">
                        <h1 class="title-1"><%= title %></h1>
                        <span class="small text-muted mt-1">Último processamento:
                            <strong><%= lastUpdate?.toLocaleString('pt-br') %></strong>
                        </span>
                    </div>
                    <div class="dashboard-filters">
                        <div class="filter-group">
                            <label for="user">Usuário</label>
                            <select class="form-control" id="user" name="user" onchange="filterBills()">
                                <% users.forEach(function(user){ %>
                                <option value="<%= user._id %>"><%= user.name %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="filter-group">
                            <label for="periodFilter">Período</label>
                            <select class="form-control" id="periodFilter" name="periodFilter" onchange="filterBills()">
                                <% var keys = Object.keys(periodFilterEnum); keys.forEach(function(pf){ %>
                                    <option value="<%= pf %>"><%= periodFilterEnum[pf] %></option>
                                <%})%>
                            </select>
                        </div>
                    </div>
                    <div id="billList" class="mt-3"></div>
                    <div class="mt-3">
                        <button id="sendNotificationBtn" class="btn btn-secondary btn-sm" onclick="sendPushNotification()">
                            Enviar notificação
                        </button>
                        <span id="notificationStatus" class="small ml-2"></span>
                    </div>
                </div>
            </div>
            <%- template.scripts %>
                <script>
                    $(document).ready(function() {
                        $('[data-toggle="tooltip"]').tooltip();
                        filterBills();
                    });

                    function applyMask() {
                        $('.money').mask('000.000.000.000.000,00', {reverse: true});
                    }

                    function filterBills() {
                        var userId = $('#user').val();
                        var filter = $('#periodFilter').val();
                        $('#billList').html('<div class="text-center py-4"><div class="spinner-border" role="status"><span class="sr-only">Carregando...</span></div></div>');
                        $('#billList').load('/dashboard/user-bill-list/?userId=' + userId + "&periodFilter=" + filter, function() {
                            applyMask();
                        });
                    }

                    function sendPushNotification() {
                        var btn = $('#sendNotificationBtn');
                        var status = $('#notificationStatus');
                        btn.prop('disabled', true);
                        status.text('Enviando...');
                        $.ajax({
                            url: '/notifications/push/send',
                            method: 'POST',
                            contentType: 'application/json',
                            data: JSON.stringify({ title: 'Lembrador de Contas', body: 'Você tem contas pendentes.' }),
                            success: function() {
                                status.text('Notificação enviada!');
                            },
                            error: function() {
                                status.text('Erro ao enviar notificação.');
                            },
                            complete: function() {
                                btn.prop('disabled', false);
                                setTimeout(function() { status.text(''); }, 4000);
                            }
                        });
                    }
                </script>
    </body>

    </html>