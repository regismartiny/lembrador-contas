<%- include ('../partials/header.ejs') %>

    <body>
        <%- template.navbar %>
            <div class="container">
                <div class="starter-template">
                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-1">
                        <h1 class="title-1 mb-0"><%= title %></h1>
                        <p class="small mb-0" style="color:var(--text-secondary)">Atualizado:
                            <strong><%= lastUpdate?.toLocaleString('pt-br') %></strong>
                        </p>
                    </div>
                    <div class="dashboard-filters">
                        <div class="filter-group">
                            <label for="user">Usuário</label>
                            <select class="form-control" id="user" name="user" onchange="filterBills()">
                                <% users.forEach(function(user){ %>
                                <option value="<%= user._id %>" <%= user._id.toString() === defaultUserId ? 'selected' : '' %>><%= user.name %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="filter-group">
                            <label for="periodFilter">Período</label>
                            <select class="form-control" id="periodFilter" name="periodFilter" onchange="filterBills()">
                                <% var keys = Object.keys(periodFilterEnum); keys.forEach(function(pf){ %>
                                    <option value="<%= pf %>"><%= periodFilterEnum[pf] %></option>
                                <%})%>
                            </select>
                        </div>
                    </div>
                    <div id="billList" class="mt-3"></div>
                </div>
            </div>
            <%- template.scripts %>
                <script>
                    async function processBills() {
                        const btn = document.getElementById('btn-process-bills');
                        if (!btn || btn.disabled) return;

                        btn.disabled = true;
                        btn.innerHTML = '<span class="spinner-border spinner-border-sm" style="width:1rem;height:1rem"></span> Processando...';

                        const billList = document.getElementById('billList');
                        if (billList) {
                            billList.innerHTML = `
                                <div class="text-center py-5">
                                    <div class="spinner-border" role="status" style="color:var(--accent);width:3rem;height:3rem"></div>
                                    <p class="mt-3 text-muted">Processando contas...</p>
                                </div>`;
                        }

                        try {
                            const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content || '';
                            await fetch('/dashboard/processBills', {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/x-www-form-urlencoded',
                                    'CSRF-Token': csrfToken
                                },
                                body: `_csrf=${encodeURIComponent(csrfToken)}`
                            });

                            if (billList) {
                                billList.innerHTML = `
                                    <div class="text-center py-5">
                                        <span style="color:var(--accent);font-size:2rem">&#10003;</span>
                                        <p class="mt-2 text-muted">Contas processadas com sucesso!</p>
                                    </div>`;
                            }

                            setTimeout(() => {
                                filterBills();
                            }, 800);

                        } catch (error) {
                            console.error('Error processing bills:', error);
                            if (billList) {
                                billList.innerHTML = `
                                    <div class="text-center py-5">
                                        <span style="color:#dc3545;font-size:2rem">&#10007;</span>
                                        <p class="mt-2 text-muted">Erro ao processar contas. Tente novamente.</p>
                                    </div>`;
                            }
                        } finally {
                            btn.disabled = false;
                            btn.innerHTML = 'Processar contas mês atual e futuros';
                        }
                    }

                    $(document).ready(function() {
                        $('[data-toggle="tooltip"]').tooltip();
                        filterBills();
                    });

                    function applyMask() {
                        $('.money').mask('000.000.000.000.000,00', {reverse: true});
                    }

                    function filterBills() {
                        var userId = $('#user').val();
                        var filter = $('#periodFilter').val();
                        $('#billList').html('<div class="text-center py-5"><div class="spinner-border" role="status" style="color:var(--accent)"><span class="sr-only">Carregando...</span></div></div>');
                        $('#billList').load('/dashboard/user-bill-list/?userId=' + userId + "&periodFilter=" + filter, function() {
                            applyMask();
                        });
                    }
                </script>
    </body>

    </html>
