<%- include ('../partials/header.ejs') %>

    <body>
        <%- template.navbar %>
            <div class="container">
                <div class="starter-template">
                    <div class="list-page-header">
                        <h1 class="title-1"><%= title %></h1>
                        <a href='/apis/new' class="btn btn-outline-success btn-sm">Novo</a>
                    </div>
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Nome</th>
                                <th>Situação</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            <% apiList.forEach(function(api){ %>
                                <tr>
                                    <td><%= api.name %></td>
                                    <td><%= statusEnum[api.status] %></td>
                                    <td class="text-nowrap">
                                        <a href='/apis/edit/<%= api._id %>'><span class="material-symbols-outlined">edit</span></a>
                                        <a href='/apis/remove/<%= api._id %>'><span class="material-symbols-outlined symbol-red">delete</span></a>
                                    </td>
                                </tr>
                            <%})%>
                        </tbody>
                    </table>
                </div>
            </div>
            <%- template.scripts %>
    </body>

    </html>
