# MongoDB connection
MONGODB_IP=192.168.2.11
MONGODB_PORT=27017
MONGODB_USER=lembradoruser
MONGODB_PASSWORD=change-me
MONGODB_DATABASE=lembrador-contas

# App port
PORT=9090

# Authentication — set APP_PASSWORD to enable the login gate.
# If unset, all routes are publicly accessible (development only).
APP_PASSWORD=change-me

# Session encryption secret — REQUIRED. Must be a long random string.
# Generate with: bun -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# The app will NOT start without this.
SESSION_SECRET=

# Web Push (VAPID) — generate with:
# node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(JSON.stringify(k,null,2))"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_MAILTO=

# Logging
LOG_LEVEL=info

# Cloudflare Access (optional) — enable auto-login via Cloudflare JWT
# CF_ACCESS_TEAM_DOMAIN=
# CF_ACCESS_AUD=
